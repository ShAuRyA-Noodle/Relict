# ─── Frontend environment variables ───────────────────────────────────
# Copy to .env.local (gitignored) for local development overrides, or
# set these in the Vercel dashboard for production.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Backend origin. Leave empty in local dev so the Vite proxy (see
# vite.config.ts) forwards /api and /ws to http://localhost:8000.
# In production (Vercel) set this to your Render backend URL, e.g.:
#   VITE_API_BASE_URL=https://relict-api.onrender.com
VITE_API_BASE_URL=
