.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Bioinformatics / scientific data ───────────────────────────────────
# Reference databases are huge and downloaded by a pinned script.
backend/data/references/
backend/data/demo/
backend/data/cache/

# Per-job workspaces and outputs (transient, not source)
backend/workspaces/
backend/outputs/
workspaces/
outputs/

# Raw sequencing files (never committed — tracked via SHA in provenance)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fasta
*.fa
*.fna
*.ffn
*.faa
*.frn
*.fasta.gz
*.fa.gz
*.sam
*.bam
*.cram
*.vcf
*.vcf.gz
*.bed.gz
*.gff.gz
*.gbk

# BLAST / vsearch binary indexes
*.ndb
*.nhr
*.nin
*.njs
*.not
*.nsq
*.ntf
*.nto
*.nhd
*.nhi
*.udb
*.sdb

# QIIME2 / BIOM artifacts produced by jobs (not fixtures)
backend/outputs/*.qza
backend/outputs/*.qzv
backend/outputs/*.biom

# Keep small fixture data (< 5 MB real truncated subsets) if we explicitly add them
!backend/tests/fixtures/**

