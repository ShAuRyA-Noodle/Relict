# ─── Secrets & environment ──────────────────────────────────────────────
# Never commit real credentials. Only .env.example (templates) are tracked.
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
*.p12
secrets/
.secrets/

# ─── Node / frontend ────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.npm/
.yarn/
.pnpm-store/
bun.lockb

# Build outputs — anchored to root so we don't ignore subdirs named "build" under src
/dist/
/dist-ssr/
/build/
/out/
/.next/
/.nuxt/
/.cache/
/.parcel-cache/
/.turbo/
/.vite/
*.tsbuildinfo

# Test & coverage
coverage/
.nyc_output/
.vitest/
__snapshots__/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Python / backend ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Python packaging artifacts — anchored under backend/ so src/lib is safe
backend/build/
backend/develop-eggs/
backend/downloads/
backend/eggs/
backend/.eggs/
backend/lib/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheels/
backend/share/python-wheels/
backend/*.egg-info/
backend/*.egg
backend/.installed.cfg
backend/MANIFEST

# Virtual envs
.venv/
venv/
ENV/
env/
.virtualenv/

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
